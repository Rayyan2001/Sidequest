{
  "expo": {
    "name": "SideQuest",
    "slug": "sidequest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sidequest",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4731",
      "newArchEnabled": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sidequest.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to scan QR codes at quest locations.",
        "NSLocationWhenInUseUsageDescription": "We need your location to find quests near you.",
        "NSUserNotificationsUsageDescription": "We use notifications to send you quest updates and rewards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A4731"
      },
      "package": "com.sidequest.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SideQuest to access your camera to scan QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SideQuest to use your location."
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
